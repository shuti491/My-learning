llm_response = await LlmManager().get_llm_connection().execute(
    execution_context=execution_context,
    prompt=prompt,
    stream=streaming_enabled,
    stage_override="PLANNER2",
    llm_call_id=llm_call_id,
    streaming_postprocessor=postprocessor
